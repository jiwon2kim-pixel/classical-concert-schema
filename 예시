<?xml version="1.0" encoding="UTF-8"?>
<!-- ============================================================
     A Metadata Vocabulary for Classical Concert Performance Records
     2023315014 김지원

     Namespaces used:
       dcterms:  Dublin Core Terms    http://purl.org/dc/terms/
       mods:     MODS 3.8             http://www.loc.gov/mods/v3
       bf:       BIBFRAME 3.0         http://id.loc.gov/ontologies/bibframe/

     Notes on bf:identifiedBy / bf:OpusNumber / bf:ThematicCatalogNumber:
       BIBFRAME is an OWL/RDF ontology and does not publish an XSD file.
       A local XSD file (bibframe-local.xsd) is provided alongside this schema, 
       defining only the bf elements used here while retaining the official bf namespace URI. 
       bf:identifiedBy is imported from that file and used with ref= as with other external elements.
    
     AI Assistance Note (using Claude):
      - Requested xs:import for dcterms and mods using published XSD files, 
        and for bf using a locally created bibframe-local.xsd 
        (since BIBFRAME is an OWL/RDF ontology with no official XSD)
      - Asked how to define a local complex type to wrap work-level elements
      - Requested xs:annotation / xs:documentation for every element from data dictionary
      - Added xs:documentation notes on XSD 1.0 design limits
      - Verified alignment between the Draft 4 data dictionary and the XSD file structure
      - Added dcterms:identifier (#9) as Work URI element to workType sequence;
        renumbered bf:identifiedBy, bf:OpusNumber, bf:ThematicCatalogNumber, dcterms:description, dcterms:relation, and work wrapper
      - Updated all xs:documentation comments to reflect revised numbering
    ============================================================ -->

<xs:schema
  xmlns:xs="http://www.w3.org/2001/XMLSchema"
  xmlns:dcterms="http://purl.org/dc/terms/"
  xmlns:mods="http://www.loc.gov/mods/v3"
  xmlns:bf="http://id.loc.gov/ontologies/bibframe/"
  targetNamespace="http://example.org/classicalConcert"
  xmlns="http://example.org/classicalConcert"
  elementFormDefault="qualified">

  <!-- xs:import: External namespaces used in this schema.
       dcterms imports from its published XSD file.
       mods is imported for ref= use of mods:name, mods:genre, etc.
       bf imports from bibframe-local.xsd, a locally created XSD
       since BIBFRAME does not publish an official XSD file. -->
  <xs:import
    namespace="http://purl.org/dc/terms/"
    schemaLocation="https://www.dublincore.org/schemas/xmls/qdc/2008/02/11/dcterms.xsd"/>

  <xs:import
    namespace="http://www.loc.gov/mods/v3"
    schemaLocation="https://www.loc.gov/standards/mods/v3/mods-3-8.xsd"/>

  <xs:import
    namespace="http://id.loc.gov/ontologies/bibframe/"
    schemaLocation="https://jiwon2kim-pixel.github.io/classical-concert-schema/bibframe-local.xsd"/>

  <!-- Root Element: classicalConcert (#0)
       A locally defined root element.
       Contains all concert-level elements directly, and work-level elements via the local <work> wrapper element (#13). -->
  <xs:element name="classicalConcert">
    <xs:complexType>
      <xs:sequence>

        <!-- #1 dcterms:title — Concert Title
             Mandatory / Non-repeatable -->
        <xs:element ref="dcterms:title"
                    minOccurs="1" maxOccurs="1">
        </xs:element>

        <!-- #3 dcterms:date — Performance Date
             Mandatory / Non-repeatable
             Values must be expressed in ISO 8601 format (YYYY-MM-DD) -->
        <xs:element ref="dcterms:date"
                    minOccurs="1" maxOccurs="1">
        </xs:element>

        <!-- #4 dcterms:spatial — Location
             Mandatory / Repeatable exactly twice (city + venue)
             @displayLabel is borrowed from MODS as a local extension attribute to differentiate city and venue values. -->
        <xs:element ref="dcterms:spatial"
                    minOccurs="2" maxOccurs="2">
        </xs:element>

        <!-- #7 mods:name [@type='personal'] — Performer
             #8 mods:name [@type='corporate'] — Ensemble
             Mandatory / Repeatable
             Both use mods:name, distinguished by @type:
               @type="personal"  → individual performer (#7)
               @type="corporate" → performing group (#8)
             Sub-elements: mods:namePart, mods:role, mods:roleTerm
             mods:roleTerm values (MARC Relator): conductor, soloist, performer -->
        <xs:element ref="mods:name"
                    minOccurs="1" maxOccurs="unbounded">
        </xs:element>

        <!-- #11 dcterms:description — Description
             Optional / Non-repeatable -->
        <xs:element ref="dcterms:description"
                    minOccurs="0" maxOccurs="1">
        </xs:element>

        <!-- #12 dcterms:relation — Related Resource
             Optional / Repeatable
             @displayLabel="recording" for audio/video links;
             @displayLabel="related" for program books, posters, etc. -->
        <xs:element ref="dcterms:relation"
                    minOccurs="0" maxOccurs="unbounded">
        </xs:element>

        <!-- #13 work — Work wrapper (local element)
             Mandatory / Repeatable (once per work performed) -->
        <xs:element name="work"
                    type="workType"
                    minOccurs="1" maxOccurs="unbounded">
        </xs:element>

      </xs:sequence>
    </xs:complexType>
  </xs:element>

  <!-- workType: Complex type for the local <work> wrapper (#13)
       Groups all work-level metadata for an individual musical work. -->
  <xs:complexType name="workType">
    <xs:sequence>

      <!-- #2 dcterms:alternative — Work Title
           Mandatory within work / Non-repeatable
           Format: [Composer]: [Genre] (No.[n]) (in [Key]), [Opus/Cat. No.]
           No. and Key may be omitted if not applicable. -->
      <xs:element ref="dcterms:alternative"
                  minOccurs="1" maxOccurs="1">
      </xs:element>

      <!-- #5 mods:genre — Genre / Form
           Mandatory within work / Non-repeatable
           Recommended controlled vocabulary: LCGFT (http://id.loc.gov/authorities/genreForms)
           Common values: Symphonies, Concertos, String quartets, Piano music, Chamber music, Overtures (Orchestral music), Operas, Choral music, etc. -->
      <xs:element ref="mods:genre"
                  minOccurs="1" maxOccurs="1">
      </xs:element>

      <!-- #6 dcterms:creator — Composer
           Mandatory within work / Non-repeatable -->
      <xs:element ref="dcterms:creator"
                  minOccurs="1" maxOccurs="1">
      </xs:element>

      <!-- #9 dcterms:identifier — Work URI
           Optional within work / Non-repeatable -->
      <xs:element ref="dcterms:identifier"
                  minOccurs="0" maxOccurs="1">
      </xs:element>

      <!-- #10    bf:identifiedBy — Identifier Wrapper
           #10-1  bf:OpusNumber — Opus Number
           #10-2  bf:ThematicCatalogNumber — Catalog Number
           Optional within work / Non-repeatable
           Defined in bibframe-local.xsd and imported above.
           Contains one of bf:OpusNumber (#10-1) or bf:ThematicCatalogNumber (#10-2). -->
      <xs:element ref="bf:identifiedBy"
                  minOccurs="0" maxOccurs="1">
      </xs:element>

    </xs:sequence>
  </xs:complexType>

</xs:schema>
